# YSK Kenjin Configuration
# Copy this file to .env and update the values for your environment.

# Path to your kendo theory/source documents directory
# This folder should contain subfolders (glossary/, articles/, blogs/) with metadata.yaml files.
# See docs/adding-content.md for the expected directory structure.
KENDO_THEORY_DIR=/path/to/your/theory/folder

# Data storage (relative paths, no need to change for default setup)
CHROMA_PERSIST_DIR=data/chroma
SQLITE_DB_PATH=data/kendocenter.db

# Embedding model (local, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Phase 2A: Re-ranking (cross-encoder, no new deps needed)
# RERANKER_ENABLED=false
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANKER_CANDIDATE_COUNT=20

# Phase 2A: Chunking (re-ingest required after changes)
# CHUNKING_MAX_TOKENS=800
# CHUNKING_OVERLAP_TOKENS=100
# CHUNKING_PREPEND_TITLE=false

# Phase 2B: Hybrid search (BM25 keyword + vector, merged via RRF)
# HYBRID_ENABLED=false
# HYBRID_RRF_K=60
# HYBRID_VECTOR_WEIGHT=1.0
# HYBRID_KEYWORD_WEIGHT=1.0
# SOURCE_QUALITY_WEIGHTS={"glossary": 1.5, "articles": 1.2}

# Phase 2B: Fuzzy glossary matching (rapidfuzz, score 0-100)
# FUZZY_ENABLED=false
# FUZZY_THRESHOLD=70.0

# Optional: Claude API key (for future direct API integration)
# ANTHROPIC_API_KEY=sk-ant-...
